module neorv32_sys_reset (
  clk_i_d,
  rstn_i_d,
  rstn_sys
)
;
input clk_i_d;
input rstn_i_d;
output rstn_sys;
wire n18_4;
wire n4_6;
wire [3:0] sreg_sys;
wire VCC;
wire GND;
  LUT4 n18_s0 (
    .F(n18_4),
    .I0(sreg_sys[3]),
    .I1(sreg_sys[2]),
    .I2(sreg_sys[1]),
    .I3(sreg_sys[0]) 
);
defparam n18_s0.INIT=16'h8000;
  DFFC sreg_sys_3_s0 (
    .Q(sreg_sys[3]),
    .D(sreg_sys[2]),
    .CLK(clk_i_d),
    .CLEAR(n4_6) 
);
  DFFC sreg_sys_2_s0 (
    .Q(sreg_sys[2]),
    .D(sreg_sys[1]),
    .CLK(clk_i_d),
    .CLEAR(n4_6) 
);
  DFFC sreg_sys_1_s0 (
    .Q(sreg_sys[1]),
    .D(sreg_sys[0]),
    .CLK(clk_i_d),
    .CLEAR(n4_6) 
);
  DFFC sreg_sys_0_s0 (
    .Q(sreg_sys[0]),
    .D(VCC),
    .CLK(clk_i_d),
    .CLEAR(n4_6) 
);
  DFFC rstn_sys_o_s0 (
    .Q(rstn_sys),
    .D(n18_4),
    .CLK(clk_i_d),
    .CLEAR(n4_6) 
);
  INV n4_s2 (
    .O(n4_6),
    .I(rstn_i_d) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* neorv32_sys_reset */
